 #define KVM_HC_SEND_IPI		10
 #define KVM_HC_SCHED_YIELD		11
 #define KVM_HC_MAP_GPA_RANGE		12
+#define KVM_HC_DMA_MAP 13
+#define KVM_HC_DMA_UNMAP 14
 
 /*
  * hypercalls use architecture specific
diff --git a/kernel/dma/direct.c b/kernel/dma/direct.c
index b8fe0b3d0..7ed2d910d 100644
--- a/kernel/dma/direct.c
+++ b/kernel/dma/direct.c
@@ -101,6 +101,7 @@ static void __dma_direct_free_pages(struct device *dev, struct page *page,
 	if (swiotlb_free(dev, page, size))
 		return;
 	dma_free_contiguous(dev, page, size);
+	kvm_hypercall2(KVM_HC_DMA_UNMAP, page_to_phys(page), size);
 }
 
 static struct page *dma_direct_alloc_swiotlb(struct device *dev, size_t size)
@@ -156,6 +157,7 @@ static struct page *__dma_direct_alloc_pages(struct device *dev, size_t size,
 		}
 	}
 
+	kvm_hypercall2(KVM_HC_DMA_MAP, page_to_phys(page), size);
 	return page;
 }
 
