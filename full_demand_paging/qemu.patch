+    return 0;
+}
+
+static int peripheral_anon_unmap(Object *child, void *opaque) {
+    if (object_get_class(child) != object_class_by_name("vfio-pci")) {
+        return 0;
+    }
+
+    VFIOPCIDevice *vdev = VFIO_PCI_DEVICE(child);
+    VFIODevice *vbasedev = &vdev->vbasedev;
+
+    struct kvm_run *run = (struct kvm_run *)opaque;
+    hwaddr iova = run->memory_fault.gpa;
+    uint64_t size = run->memory_fault.size;
+
+    int r = vfio_container_dma_unmap(vbasedev->bcontainer, iova, size, NULL, false);
+    if (r < 0) {
+        perror("[chengyan] vfio_container_dma_unmap");
+    }
+    return 0;
+}
+
+static int demand_dma(X86CPU *cpu, struct kvm_run *run, bool map) {
+    Object* obj = object_resolve_path_at(OBJECT(current_machine), "peripheral-anon");
+    if (obj) {
+        if (map) {
+            object_child_foreach(obj, peripheral_anon_map, (void *)run);
+        } else {
+            object_child_foreach(obj, peripheral_anon_unmap, (void *)run);
+        }
+    }
+    return 0;
+}
+
 static int kvm_handle_hypercall(X86CPU *cpu, struct kvm_run *run)
 {
     if (run->hypercall.nr == KVM_HC_MAP_GPA_RANGE)
         return kvm_handle_hc_map_gpa_range(cpu, run);
-
+    if (run->hypercall.nr == KVM_HC_DMA_MAP) {
+        fprintf(stderr, "[chengyan] KVM_HC_DMA_MAP: gpa = 0x%llx, size = %llu\n", run->hypercall.args[0], run->hypercall.args[1]);
+        return demand_dma(cpu, run, true);
+    }
+    if (run->hypercall.nr == KVM_HC_DMA_UNMAP) {
+        fprintf(stderr, "[chengyan] KVM_HC_DMA_UNMAP: gpa = 0x%llx, size = %llu\n", run->hypercall.args[0], run->hypercall.args[1]);
+        return demand_dma(cpu, run, false);
+    }
     return -EINVAL;
 }
 
