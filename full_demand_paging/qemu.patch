+    VFIODevice *vbasedev = &vdev->vbasedev;
+
+    struct kvm_run *run = (struct kvm_run *)opaque;
+    hwaddr iova = run->memory_fault.gpa;
+    uint64_t size = run->memory_fault.size;
+
+    MemoryRegionSection section = memory_region_find(get_system_memory(), iova, size);
+    if (!memory_region_is_ram(section.mr) &&
+        !memory_region_is_iommu(section.mr)) {
+        return 0;
+    }
+
+    //fprintf(stderr, "[chengyan] section.mr->name = %s\n", section.mr->name);
+    void* mr_start = memory_region_get_ram_ptr(section.mr);
